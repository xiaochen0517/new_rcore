{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start QEMU Debug Server",
      "type": "shell",
      "command": "make",
      "args": ["debug-run"],
      "options": {
        "cwd": "${workspaceFolder}/os"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*qemu-system-riscv64.*",
          "endsPattern": "^.*Starting QEMU in debug mode.*"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Wait Before Debug",
      "type": "shell",
      "command": "sleep",
      "args": ["1"],
      "dependsOn": ["Start QEMU Debug Server"],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
