{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    // gdb-mutilarch 调试内核
    {
      "name": "Debug Kernel with gdb-multiarch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/os/target/riscv64gc-unknown-none-elf/release/os",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb-multiarch",
      "preLaunchTask": "Wait Before Debug",
      "setupCommands": [
        {
          "description": "Set RISC-V architecture",
          "text": "set architecture riscv:rv64",
          "ignoreFailures": true
        },
        {
          "description": "Set remote target",
          "text": "target remote :1234",
          "ignoreFailures": true
        },
        // 可以使用以下配置追加用户程序中的符号用于调试特定应用
        // 但是由于所有的程序在批处理操作系统中都是要加载到 0x80400000 地址，所以断点会影响到所有在此内存空间中依次执行的程序
        // 所以在添加断点时需要确保当前加载执行的程序是你想要调试的程序
        // {
        //   "description": "Add user app symbol file",
        //   "text": "add-symbol-file ${workspaceFolder}/user/target/riscv64gc-unknown-none-elf/release/00hello_world 0x80400000",
        //   "ignoreFailures": true
        // },
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}